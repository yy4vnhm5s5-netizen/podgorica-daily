# Optional deployment context for observability and configuration checks.
NEXT_PUBLIC_APP_ENV=development
# Set this to the public HTTPS origin before deployment, without a trailing path.
# NEXT_PUBLIC_SITE_URL=https://podgorica.example
# All file-backed provider caches resolve below this directory unless explicitly overridden.
# Set RUNTIME_DATA_DIR=/app/.runtime when using a Railway Volume mounted at /app/.runtime.
RUNTIME_DATA_DIR=.runtime
# Optional explicit cache roots. They default to $RUNTIME_DATA_DIR/cache.
# EVENT_CACHE_DIR=.runtime/cache
# EVENT_REFRESH_SECRET=replace-with-a-strong-server-only-secret
# CITY_ALERTS_REFRESH_SECRET=replace-with-a-different-strong-server-only-secret
# Railway: keep this server-only value on the web service and its 30-minute Cron trigger.
# The trigger posts to /api/internal/city-alerts/refresh; do not expose this value to the browser.
DEFAULT_CITY=podgorica
ENABLE_WEATHER=true
ENABLE_CEDIS=true
ENABLE_AMSCG=true
ENABLE_VIKPG=true
ENABLE_EVENTS=false

# CEDIS reads its cached official data only. `mock` is development-only and must be explicit.
CEDIS_PROVIDER_MODE=live
AMSCG_PROVIDER_MODE=live
VIKPG_PROVIDER_MODE=live
# CEDIS_CACHE_PATH=.runtime/cache/cedis-planned-outages.json
# AMSCG_CACHE_PATH=.runtime/cache/amscg-road-conditions.json
# VIKPG_CACHE_PATH=.runtime/cache/vikpg-water-alerts.json

# Event collectors/providers are enabled only in live mode. Mock mode is explicit and rejected in production.
EVENT_PROVIDER_MODE=disabled
# EVENT_CACHE_PATH=.runtime/cache/events.json
EVENT_CACHE_FRESHNESS_MINUTES=120
EVENT_MAX_QUERY_RANGE_DAYS=90
EVENT_MAX_RECURRENCE_OCCURRENCES=30
# KIC_EVENT_CACHE_PATH=.runtime/cache/kic-events.json
# CNP_EVENT_CACHE_PATH=.runtime/cache/cnp-events.json
# GLAVNI_GRAD_EVENT_CACHE_PATH=.runtime/cache/glavni-grad-events.json
# TOURISM_EVENT_CACHE_PATH=.runtime/cache/tourism-events.json
EVENT_QUALITY_MAX_PAST_DAYS=30
EVENT_QUALITY_MAX_FUTURE_DAYS=366
EVENT_QUALITY_MIN_SCORE=50
EVENT_QUALITY_WARN_MISSING_DESCRIPTION=true
EVENT_QUALITY_WARN_MISSING_VENUE=true
EVENT_QUALITY_WARN_MISSING_START_TIME=true
EVENT_QUALITY_COUNT_DROP_RATIO=0.5
EVENT_QUALITY_DEGRADED_WARNING_RATE=0.4
EVENT_QUALITY_FAILING_REJECTION_RATE=0.5
