{
  "name": "podgorica-daily",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "collect:cedis": "node --experimental-strip-types src/modules/city-alerts/infrastructure/collect-cedis.ts",
    "collect:amscg": "node --experimental-strip-types src/modules/city-alerts/infrastructure/collect-amscg.ts",
    "collect:vikpg": "node --experimental-strip-types src/modules/city-alerts/infrastructure/collect-vikpg.ts",
    "collect:zpcg-railway": "node --experimental-strip-types src/modules/transport/infrastructure/collect-zpcg-railway.ts",
    "collect:podgorica-flights": "node --experimental-strip-types src/modules/flights/infrastructure/collect-podgorica-flights.ts",
    "collect:montegigs-going-out": "node --experimental-strip-types src/modules/going-out/infrastructure/collect-montegigs-going-out.ts",
    "collect:kic-events": "node --experimental-strip-types src/modules/events/infrastructure/collect-kic-events.ts",
    "collect:cnp-events": "node --experimental-strip-types src/modules/events/infrastructure/collect-cnp-events.ts",
    "collect:glavni-grad-events": "node --experimental-strip-types src/modules/events/infrastructure/collect-glavni-grad-events.ts",
    "collect:tourism-events": "node --experimental-strip-types src/modules/events/infrastructure/collect-tourism-events.ts",
    "collect:cineplexx-events": "node --experimental-strip-types src/modules/events/infrastructure/collect-cineplexx-events.ts",
    "events:refresh": "node --experimental-strip-types src/modules/events/infrastructure/collect-events.ts",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:flights": "node --experimental-strip-types --import ./scripts/register-test-path-aliases.mjs --test src/modules/flights/domain/flight.test.ts src/modules/flights/infrastructure/podgorica-flights.test.ts src/modules/flights/infrastructure/collect-podgorica-flights.test.ts src/modules/flights/presentation/podgorica-flights-ui-model.test.ts",
    "test:going-out": "node --experimental-strip-types --import ./scripts/register-test-path-aliases.mjs --test src/modules/going-out/domain/going-out-event.test.ts src/modules/going-out/infrastructure/montegigs-going-out.test.ts src/modules/going-out/infrastructure/collect-montegigs-going-out.test.ts src/modules/going-out/presentation/going-out-ui-model.test.ts",
    "test": "node --experimental-strip-types --import ./scripts/register-test-path-aliases.mjs --test $(find src -name '*.test.ts' -print)",
    "typecheck": "tsc --noEmit",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,md,yml,yaml}": "prettier --write"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^15.5.0",
    "nodemailer": "^9.0.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.5.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2"
  }
}
